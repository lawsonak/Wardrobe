// Wardrobe DB schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())

  items         Item[]
  outfits       Outfit[]
  wishlistItems WishlistItem[]
  brands        Brand[]
  collections   Collection[]
  notifications Notification[]
  itemSets      ItemSet[]
  activityLogs  ActivityLog[]
  looks         Look[]
}

model Item {
  id                 String   @id @default(cuid())
  ownerId            String
  owner              User     @relation(fields: [ownerId], references: [id])
  imagePath          String
  // Optional pointer to the untouched, full-resolution upload kept on
  // disk alongside the display-sized `imagePath`. The item detail page
  // serves this when the user taps the hero to zoom; everything else
  // (closet grid, outfit cards, AI try-on) renders the much smaller
  // `imagePath`. Items uploaded before this column existed leave it
  // null and the lightbox falls back to `imagePath`.
  imageOriginalPath  String?
  imageBgRemovedPath String?
  // Full-resolution background-removed cutout. Generated server-side
  // from imageOriginalPath (slower / better edge fidelity than the
  // browser-side path), used only by the lightbox tap-to-zoom so the
  // user sees a real garment cutout instead of pixel mush at zoom.
  // Background work fires after upload; null until ready.
  imageBgRemovedOriginalPath String?
  // Perceptual hash (dHash, 64 bits as 16 hex chars) of the photo at
  // upload time. Compared via Hamming distance against the rest of
  // the closet on /api/items POST so the user gets a "you might
  // already own this" warning when they accidentally photograph the
  // same garment twice. Null on items uploaded before this shipped.
  phash              String?
  // active | needs_review | draft
  status             String   @default("active")
  category           String
  subType            String?
  color              String?
  // Free-form display string. Kept for backward compatibility / quick add.
  brand              String?
  // Optional canonical brand reference. When set, overrides `brand` for display.
  brandId            String?
  brandRef           Brand?  @relation(fields: [brandId], references: [id])
  size               String?
  // Optional sizing system (alpha, numeric, eu, us, jeans, bra, ring, etc).
  sizeSystem         String?
  // Per-category structured measurements as JSON. Free-form schema so we
  // can extend without migrations; rendered by a category-aware editor.
  fitDetails         String?
  fitNotes           String?
  // JSON blob of pending AI suggestions for fields that already have
  // a value, staged from a bulk re-tag run. The item edit page reads
  // this on load and surfaces a per-row review panel so the user can
  // approve/reject each change. Cleared once the user applies or
  // rejects. Null when there's nothing pending. See lib/pendingAi.ts
  // for the schema.
  pendingAiSuggestions String?
  // Comma-separated lists (SQLite has no array type)
  seasons            String   @default("")
  activities         String   @default("")
  notes              String?
  isFavorite         Boolean  @default(false)
  // "Backroom" flag — items the user wants hidden from the default
  // closet view, outfit builder, collection picker, and AI prompts.
  // Toggle-able back into view via a per-page filter; the dedicated
  // /wardrobe/backroom page lives behind a lock icon in the closet
  // header. Outfits / Collections that contain a Backroom item are
  // hidden by the same toggle via an EXISTS join — no separate
  // column on Outfit / Collection.
  isBackroom         Boolean  @default(false)
  // "Beauty" flag — cosmetic / skincare / fragrance / tools.
  // Mirrors the isBackroom hide pattern: when true, the item is
  // hard-excluded from the main closet view, outfit builder,
  // collection picker, and AI catalog. Lives instead on the
  // dedicated /wardrobe/beauty page reachable via a 💄 icon in
  // the closet header. Independent of isBackroom — a beauty item
  // can also be Spicy.
  isBeauty           Boolean  @default(false)
  // Cosmetic shade name + optional hex visualization. Free-text
  // because every brand names shades differently
  // ("Ruby Woo", "Russian Red", "MAC 311"). Hex drives a small
  // colored dot on the gallery tile so the user can scan-match
  // visually.
  shadeName          String?
  shadeHex           String?
  // Free-text finish (matte / satin / gloss / cream / shimmer /
  // glitter / metallic / sheer …). Datalist suggestions are baked
  // into the form, but the column accepts anything so brand-
  // specific terms like "soft matte" survive.
  finish             String?
  // Optional link to a "matching set" — e.g. a swimsuit's top + bottom
  // bought together. Items in a set still belong to the closet
  // independently and can be mixed and matched in any outfit.
  setId              String?
  set                ItemSet? @relation(fields: [setId], references: [id], onDelete: SetNull)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  outfitItems     OutfitItem[]
  collectionItems CollectionItem[]
  photos          ItemPhoto[]
  lookItems       LookItem[]

  @@index([ownerId])
  @@index([ownerId, isBackroom])
  @@index([ownerId, isBeauty])
}

// A "Look" — bundle of beauty items that go together as a routine
// ("Everyday face", "Date night smoky", "Wedding glam"). Parallels
// Outfit but for cosmetics; standalone or paired one-to-one with an
// Outfit via Outfit.lookId.
model Look {
  id        String     @id @default(cuid())
  ownerId   String
  owner     User       @relation(fields: [ownerId], references: [id])
  name      String
  notes     String?
  items     LookItem[]
  outfits   Outfit[]   @relation("OutfitLook")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([ownerId])
}

model LookItem {
  id      String @id @default(cuid())
  lookId  String
  look    Look   @relation(fields: [lookId], references: [id], onDelete: Cascade)
  itemId  String
  item    Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  // One of LOOK_SLOTS in lib/constants.ts (Lipstick, Mascara, Foundation, …).
  // Free string so the schema doesn't gate adding a slot later.
  slot    String

  @@index([lookId])
  @@index([itemId])
}

// A "matching set" of items that came together — like a swimsuit
// top + bottom, or a pajama top + bottoms. Items keep their
// independence in the closet (you can wear just the top with
// different bottoms); the set is a soft link for "these go together
// when you want them to."
model ItemSet {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  name      String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items     Item[]

  @@index([ownerId])
}

// Additional photo angles for an item (front already lives on Item
// itself as imagePath/imageBgRemovedPath; this is for back / side /
// detail / etc.). Each angle optionally has its own bg-removed
// cutout and a free-text label.
model ItemPhoto {
  id                 String   @id @default(cuid())
  itemId             String
  item               Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  // "angle" (default) for additional full-body shots, "label" for
  // tag / care-symbol close-ups. Originally Item.labelImagePath stored
  // a single label per item; consolidating into ItemPhoto lets each
  // item carry many labels (front of tag, back of tag, brand, care
  // symbols) without a separate model. AI auto-tag reads the oldest
  // kind=label row by createdAt.
  kind               String   @default("angle")
  imagePath          String
  // Same two-tier shape as Item: full-resolution copy preserved on
  // disk so the carousel's tap-to-zoom shows real detail.
  imageOriginalPath  String?
  imageBgRemovedPath String?
  // Free-form label, e.g. "back", "side", "detail of the buttons".
  label              String?
  // Lower numbers render first in the thumbnail strip.
  position           Int      @default(0)
  createdAt          DateTime @default(now())

  @@index([itemId])
}

model Outfit {
  id         String   @id @default(cuid())
  ownerId    String
  owner      User     @relation(fields: [ownerId], references: [id])
  name       String
  activity   String?
  season     String?
  isFavorite Boolean  @default(false)
  // Style-canvas layout, JSON-encoded. Optional — outfits without a saved
  // layout fall back to category-driven defaults at render time.
  layoutJson String?
  // AI try-on: composited mannequin-wearing-outfit image generated by
  // Gemini 2.5 Flash Image. `tryOnHash` fingerprints the inputs that
  // produced it (mannequin id, sorted item ids, item file mtimes, prompt
  // version) so the route can short-circuit regeneration when nothing
  // has changed.
  tryOnImagePath   String?
  tryOnHash        String?
  tryOnGeneratedAt DateTime?
  // Optional back-link to the Collection that generated this outfit.
  // Detached from a collection = standalone outfit.
  collectionId String?
  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  // Optional one-to-one pairing with a saved makeup Look. Set on the
  // Outfit Builder via a "Pair with a Look" picker; null when the
  // outfit isn't tied to a specific face routine.
  lookId       String?
  look         Look?    @relation("OutfitLook", fields: [lookId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items OutfitItem[]

  @@index([ownerId])
}

// Canonical brand. The `nameKey` is a normalized version of `name`
// (lowercase, alphanumeric only) so we can dedupe "J Crew" / "J.Crew" /
// "JCREW". Aliases let the user merge variant spellings into one canonical
// brand without losing existing data.
model Brand {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  name      String
  nameKey   String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items   Item[]
  aliases BrandAlias[]

  @@unique([ownerId, nameKey])
}

model BrandAlias {
  id      String @id @default(cuid())
  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)
  alias   String
  aliasKey String

  @@unique([brandId, aliasKey])
}

// A user-curated subset of items — typically a packing list for a trip
// ("Lisbon · May 5–10") but also general themed sets ("Date night",
// "Work week"). Items can belong to many collections.
model Collection {
  id          String    @id @default(cuid())
  ownerId     String
  owner       User      @relation(fields: [ownerId], references: [id])
  // "trip" | "general" — drives which fields the UI shows.
  kind        String    @default("general")
  name        String
  description String?
  // Trip-specific. All optional so general collections can leave them blank.
  destination String?
  startDate   DateTime?
  endDate     DateTime?
  // Free-form trip notes ("pack a light layer for evenings"). Distinct
  // from `description` so we can keep AI-suggested tips separate.
  notes       String?
  // Legacy / general-collection fields.
  occasion    String?
  season      String?
  // CSV of activity tags (ACTIVITIES enum + free-form like "hiking").
  activities  String    @default("")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  items   CollectionItem[]
  outfits Outfit[]

  @@index([ownerId])
}

model CollectionItem {
  id           String     @id @default(cuid())
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  itemId       String
  // Cascade so deleting an item cleans up its collection memberships
  // automatically. The item delete handler also calls deleteMany on
  // these rows explicitly — belt and braces, since older DBs that
  // pre-date this migration won't have the cascade until they migrate.
  item         Item       @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([collectionId, itemId])
}

// Lightweight in-app notifications (batch upload finished, items waiting
// for review, etc.). Read by the bell in the header.
model Notification {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  title     String
  body      String?
  href      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([ownerId, read, createdAt])
}

model OutfitItem {
  id       String @id @default(cuid())
  outfitId String
  outfit   Outfit @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  itemId   String
  item     Item   @relation(fields: [itemId], references: [id])
  slot     String
}

model WishlistItem {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  name      String
  category  String?
  brand     String?
  link      String?
  price     String?
  imagePath String?
  // low | medium | high
  priority  String   @default("medium")
  occasion  String?
  notes     String?
  fillsGap  Boolean  @default(false)
  giftIdea  Boolean  @default(false)
  purchased Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Per-user audit feed surfaced on the Settings page. Logs CRUD writes,
// AI invocations, and sign-ins so each profile can see a chronological
// "what's been happening" view of their own usage. Strictly per-user —
// no cross-profile reads. Auto-pruned to ~90 days by `lib/activity.ts`
// every time a new row is written.
model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Stable kind code, e.g. "item.create", "outfit.update", "ai.tryon",
  // "auth.signin". The settings UI groups by prefix.
  kind       String
  // Short human-readable description rendered in the activity list.
  // Capped at 200 chars on write so a runaway summary can't bloat
  // the table.
  summary    String
  // Optional pointer back to the row this activity refers to. Lets
  // the UI link list rows to detail pages where it makes sense.
  targetType String?
  targetId   String?
  // Optional structured metadata (JSON-encoded). Free-form schema so
  // we can extend without migrations.
  meta       String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
}
