// Wardrobe DB schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())

  items         Item[]
  outfits       Outfit[]
  wishlistItems WishlistItem[]
  brands        Brand[]
  capsules      Capsule[]
  notifications Notification[]
}

model Item {
  id                 String   @id @default(cuid())
  ownerId            String
  owner              User     @relation(fields: [ownerId], references: [id])
  imagePath          String
  imageBgRemovedPath String?
  labelImagePath     String?
  // active | needs_review | draft
  status             String   @default("active")
  category           String
  subType            String?
  color              String?
  // Free-form display string. Kept for backward compatibility / quick add.
  brand              String?
  // Optional canonical brand reference. When set, overrides `brand` for display.
  brandId            String?
  brandRef           Brand?  @relation(fields: [brandId], references: [id])
  size               String?
  // Optional sizing system (alpha, numeric, eu, us, jeans, bra, ring, etc).
  sizeSystem         String?
  // Per-category structured measurements as JSON. Free-form schema so we
  // can extend without migrations; rendered by a category-aware editor.
  fitDetails         String?
  fitNotes           String?
  // Comma-separated lists (SQLite has no array type)
  seasons            String   @default("")
  activities         String   @default("")
  notes              String?
  isFavorite         Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  outfitItems  OutfitItem[]
  capsuleItems CapsuleItem[]
}

model Outfit {
  id         String   @id @default(cuid())
  ownerId    String
  owner      User     @relation(fields: [ownerId], references: [id])
  name       String
  activity   String?
  season     String?
  isFavorite Boolean  @default(false)
  // Style-canvas layout, JSON-encoded. Optional — outfits without a saved
  // layout fall back to category-driven defaults at render time.
  layoutJson String?
  // AI try-on: composited mannequin-wearing-outfit image generated by
  // Gemini 2.5 Flash Image. `tryOnHash` fingerprints the inputs that
  // produced it (mannequin id, item set, item file mtimes, prompt
  // version) so we can short-circuit regeneration when nothing changed.
  tryOnImagePath   String?
  tryOnHash        String?
  tryOnGeneratedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  items OutfitItem[]
}

// Canonical brand. The `nameKey` is a normalized version of `name`
// (lowercase, alphanumeric only) so we can dedupe "J Crew" / "J.Crew" /
// "JCREW". Aliases let the user merge variant spellings into one canonical
// brand without losing existing data.
model Brand {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  name      String
  nameKey   String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items   Item[]
  aliases BrandAlias[]

  @@unique([ownerId, nameKey])
}

model BrandAlias {
  id      String @id @default(cuid())
  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)
  alias   String
  aliasKey String

  @@unique([brandId, aliasKey])
}

// A user-curated subset of items. "Paris trip", "Summer vacation",
// "Date-night capsule" — anything. Items can belong to many capsules.
model Capsule {
  id          String   @id @default(cuid())
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])
  name        String
  description String?
  occasion    String?
  season      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items CapsuleItem[]
}

model CapsuleItem {
  id        String  @id @default(cuid())
  capsuleId String
  capsule   Capsule @relation(fields: [capsuleId], references: [id], onDelete: Cascade)
  itemId    String
  item      Item    @relation(fields: [itemId], references: [id])

  @@unique([capsuleId, itemId])
}

// Lightweight in-app notifications (batch upload finished, items waiting
// for review, etc.). Read by the bell in the header.
model Notification {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  title     String
  body      String?
  href      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([ownerId, read, createdAt])
}

model OutfitItem {
  id       String @id @default(cuid())
  outfitId String
  outfit   Outfit @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  itemId   String
  item     Item   @relation(fields: [itemId], references: [id])
  slot     String
}

model WishlistItem {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  name      String
  category  String?
  brand     String?
  link      String?
  price     String?
  imagePath String?
  // low | medium | high
  priority  String   @default("medium")
  occasion  String?
  notes     String?
  fillsGap  Boolean  @default(false)
  giftIdea  Boolean  @default(false)
  purchased Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
