// Wardrobe DB schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())

  items         Item[]
  outfits       Outfit[]
  wishlistItems WishlistItem[]
  brands        Brand[]
  collections   Collection[]
  notifications Notification[]
  itemSets      ItemSet[]
}

model Item {
  id                 String   @id @default(cuid())
  ownerId            String
  owner              User     @relation(fields: [ownerId], references: [id])
  imagePath          String
  imageBgRemovedPath String?
  labelImagePath     String?
  // active | needs_review | draft
  status             String   @default("active")
  category           String
  subType            String?
  color              String?
  // Free-form display string. Kept for backward compatibility / quick add.
  brand              String?
  // Optional canonical brand reference. When set, overrides `brand` for display.
  brandId            String?
  brandRef           Brand?  @relation(fields: [brandId], references: [id])
  size               String?
  // Optional sizing system (alpha, numeric, eu, us, jeans, bra, ring, etc).
  sizeSystem         String?
  // Per-category structured measurements as JSON. Free-form schema so we
  // can extend without migrations; rendered by a category-aware editor.
  fitDetails         String?
  fitNotes           String?
  // Comma-separated lists (SQLite has no array type)
  seasons            String   @default("")
  activities         String   @default("")
  notes              String?
  isFavorite         Boolean  @default(false)
  // Optional link to a "matching set" — e.g. a swimsuit's top + bottom
  // bought together. Items in a set still belong to the closet
  // independently and can be mixed and matched in any outfit.
  setId              String?
  set                ItemSet? @relation(fields: [setId], references: [id], onDelete: SetNull)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  outfitItems     OutfitItem[]
  collectionItems CollectionItem[]
  photos          ItemPhoto[]
}

// A "matching set" of items that came together — like a swimsuit
// top + bottom, or a pajama top + bottoms. Items keep their
// independence in the closet (you can wear just the top with
// different bottoms); the set is a soft link for "these go together
// when you want them to."
model ItemSet {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  name      String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items     Item[]

  @@index([ownerId])
}

// Additional photo angles for an item (front already lives on Item
// itself as imagePath/imageBgRemovedPath; this is for back / side /
// detail / etc.). Each angle optionally has its own bg-removed
// cutout and a free-text label.
model ItemPhoto {
  id                 String   @id @default(cuid())
  itemId             String
  item               Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  imagePath          String
  imageBgRemovedPath String?
  // Free-form label, e.g. "back", "side", "detail of the buttons".
  label              String?
  // Lower numbers render first in the thumbnail strip.
  position           Int      @default(0)
  createdAt          DateTime @default(now())

  @@index([itemId])
}

model Outfit {
  id         String   @id @default(cuid())
  ownerId    String
  owner      User     @relation(fields: [ownerId], references: [id])
  name       String
  activity   String?
  season     String?
  isFavorite Boolean  @default(false)
  // Style-canvas layout, JSON-encoded. Optional — outfits without a saved
  // layout fall back to category-driven defaults at render time.
  layoutJson String?
  // Optional back-link to the Collection that generated this outfit.
  // Detached from a collection = standalone outfit.
  collectionId String?
  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items OutfitItem[]
}

// Canonical brand. The `nameKey` is a normalized version of `name`
// (lowercase, alphanumeric only) so we can dedupe "J Crew" / "J.Crew" /
// "JCREW". Aliases let the user merge variant spellings into one canonical
// brand without losing existing data.
model Brand {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  name      String
  nameKey   String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items   Item[]
  aliases BrandAlias[]

  @@unique([ownerId, nameKey])
}

model BrandAlias {
  id      String @id @default(cuid())
  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)
  alias   String
  aliasKey String

  @@unique([brandId, aliasKey])
}

// A user-curated subset of items — typically a packing list for a trip
// ("Lisbon · May 5–10") but also general themed sets ("Date night",
// "Work week"). Items can belong to many collections.
model Collection {
  id          String    @id @default(cuid())
  ownerId     String
  owner       User      @relation(fields: [ownerId], references: [id])
  // "trip" | "general" — drives which fields the UI shows.
  kind        String    @default("general")
  name        String
  description String?
  // Trip-specific. All optional so general collections can leave them blank.
  destination String?
  startDate   DateTime?
  endDate     DateTime?
  // Free-form trip notes ("pack a light layer for evenings"). Distinct
  // from `description` so we can keep AI-suggested tips separate.
  notes       String?
  // Legacy / general-collection fields.
  occasion    String?
  season      String?
  // CSV of activity tags (ACTIVITIES enum + free-form like "hiking").
  activities  String    @default("")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  items   CollectionItem[]
  outfits Outfit[]
}

model CollectionItem {
  id           String     @id @default(cuid())
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  itemId       String
  item         Item       @relation(fields: [itemId], references: [id])

  @@unique([collectionId, itemId])
}

// Lightweight in-app notifications (batch upload finished, items waiting
// for review, etc.). Read by the bell in the header.
model Notification {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  title     String
  body      String?
  href      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([ownerId, read, createdAt])
}

model OutfitItem {
  id       String @id @default(cuid())
  outfitId String
  outfit   Outfit @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  itemId   String
  item     Item   @relation(fields: [itemId], references: [id])
  slot     String
}

model WishlistItem {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  name      String
  category  String?
  brand     String?
  link      String?
  price     String?
  imagePath String?
  // low | medium | high
  priority  String   @default("medium")
  occasion  String?
  notes     String?
  fillsGap  Boolean  @default(false)
  giftIdea  Boolean  @default(false)
  purchased Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
