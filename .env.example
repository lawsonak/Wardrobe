# Local SQLite database
# Prisma resolves `file:` paths relative to prisma/schema.prisma,
# so this lands at <project>/data/wardrobe.db.
DATABASE_URL="file:../data/wardrobe.db"

# Auth.js secret - generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-random-string"

# Wife's account (the gift recipient)
HER_NAME="Your Wife's Name"
HER_EMAIL="her@example.com"
HER_PASSWORD="change-me"

# Your account
HIS_NAME="Your Name"
HIS_EMAIL="you@example.com"
HIS_PASSWORD="change-me"

# Optional: AI auto-tagging on item upload. Disabled by default.
# Provider stubs ship with the app — drop in your own implementation
# in lib/ai/provider.ts to wire a real call. AI never auto-saves;
# suggestions are surfaced for the user to accept or ignore.
# AI_PROVIDER="gemini"
# GEMINI_API_KEY=""
# Pick any Flash model — Pro is paid-only on this API and 429s on the free tier.
# Defaults to gemini-2.0-flash if unset. Recommended: gemini-2.5-flash.
# GEMINI_MODEL="gemini-2.5-flash"
# Image-output model used by the per-user mannequin generator in Settings.
# When unset, the app tries a fallback chain of known image-out models
# and uses the first one your API key has access to. Override only to
# pin a specific model.
# GEMINI_IMAGE_MODEL="gemini-2.0-flash-preview-image-generation"
# AI_PROVIDER="openai"
# OPENAI_API_KEY=""

# Google Programmable Search (Custom Search JSON API). Required for the
# "Shop for this trip" feature on Collections — Gemini specs the products
# and CSE resolves each spec to a real, currently-stocked URL from the
# retailers you configure in your search engine.
#
# Setup:
#   1. Create a Programmable Search Engine at
#      https://programmablesearchengine.google.com/ and add the fashion
#      retailers you want to search across (e.g. madewell.com, jcrew.com,
#      reformation.com, net-a-porter.com, ssense.com, …).
#   2. Copy the "Search engine ID" into GOOGLE_CSE_ID below.
#   3. Enable "Custom Search API" in Google Cloud, create an API key,
#      paste it into GOOGLE_CSE_API_KEY.
# Free tier: 100 queries/day, then $5 per 1000 queries.
# GOOGLE_CSE_API_KEY=""
# GOOGLE_CSE_ID=""
